{
    "swagger": "2.0",
    "info": {
        "description": "Backend for the lowkeymycity.com city vibe-check quiz.",
        "title": "LowkeyMyCity API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/api/v1",
    "paths": {
        "/cities": {
            "get": {
                "description": "Every city label the validator accepts, ordered by population descending.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "cities"
                ],
                "summary": "US city list",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/echo.HTTPError"
                        }
                    }
                }
            }
        },
        "/quiz": {
            "get": {
                "description": "Question set for a quiz run: fixed bank for match mode, LLM-generated cached questions for city mode.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "quiz"
                ],
                "summary": "Quiz questions",
                "parameters": [
                    {
                        "enum": [
                            "match",
                            "city"
                        ],
                        "type": "string",
                        "description": "quiz mode, strictly one of the enum",
                        "name": "mode",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "known US city name; required when mode=city",
                        "name": "city",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/internal_quiz.GetQuestionsResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/echo.HTTPError"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/echo.HTTPError"
                        }
                    }
                }
            }
        },
        "/quiz/result": {
            "post": {
                "description": "Stores (or reuses) the verdict for an answer combination and returns it with its permanent id.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "quiz"
                ],
                "summary": "Submit quiz answers",
                "parameters": [
                    {
                        "description": "quiz answers",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_quiz.GetResultsRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/lowkeymycity_pkg_types.QuizResult"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/echo.HTTPError"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/echo.HTTPError"
                        }
                    }
                }
            }
        },
        "/results/{id}": {
            "get": {
                "description": "The stored verdict for one result id, as shown on the result page.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "results"
                ],
                "summary": "Stored quiz result",
                "parameters": [
                    {
                        "type": "string",
                        "description": "result id",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/lowkeymycity_pkg_types.QuizResult"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/echo.HTTPError"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/echo.HTTPError"
                        }
                    }
                }
            }
        },
        "/results/{id}/pdf": {
            "get": {
                "description": "The stored verdict rendered as a one-page A4 PDF (\"keep the receipts\").",
                "produces": [
                    "application/pdf"
                ],
                "tags": [
                    "results"
                ],
                "summary": "Result as PDF",
                "parameters": [
                    {
                        "type": "string",
                        "description": "result id",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "file"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/echo.HTTPError"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/echo.HTTPError"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "echo.HTTPError": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string"
                }
            }
        },
        "internal_quiz.Answer": {
            "type": "object",
            "required": [
                "answer",
                "question",
                "questionId"
            ],
            "properties": {
                "answer": {
                    "type": "string"
                },
                "question": {
                    "type": "string"
                },
                "questionId": {
                    "type": "string"
                }
            }
        },
        "internal_quiz.GetQuestionsResponse": {
            "type": "object",
            "properties": {
                "city": {
                    "type": "string"
                },
                "questions": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/internal_quiz.QuestionResponse"
                    }
                }
            }
        },
        "internal_quiz.GetResultsRequest": {
            "type": "object",
            "required": [
                "answers",
                "mode"
            ],
            "properties": {
                "answers": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/definitions/internal_quiz.Answer"
                    }
                },
                "city": {
                    "type": "string"
                },
                "mode": {
                    "type": "string",
                    "enum": [
                        "match",
                        "city"
                    ]
                }
            }
        },
        "internal_quiz.QuestionResponse": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string"
                },
                "options": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "text": {
                    "type": "string"
                }
            }
        },
        "lowkeymycity_pkg_types.Alternative": {
            "type": "object",
            "properties": {
                "blurb": {
                    "type": "string"
                },
                "city": {
                    "type": "string"
                }
            }
        },
        "lowkeymycity_pkg_types.QuizResult": {
            "type": "object",
            "properties": {
                "alternatives": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/lowkeymycity_pkg_types.Alternative"
                    }
                },
                "city": {
                    "type": "string"
                },
                "closing": {
                    "type": "string"
                },
                "greenFlags": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "id": {
                    "type": "string"
                },
                "mode": {
                    "type": "string"
                },
                "redFlags": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "score": {
                    "type": "integer"
                },
                "summary": {
                    "type": "string"
                },
                "title": {
                    "type": "string"
                }
            }
        }
    }
}